# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Database ---
# App/worker runtime connection: a restricted, non-superuser role (created by
# docker/postgres/init.sh) so Postgres row-level-security policies are actually
# enforced -- RLS is bypassed for superusers regardless of FORCE ROW LEVEL SECURITY.
APP_DB_PASSWORD=rag_app
DATABASE_URL=postgresql+asyncpg://rag_app:rag_app@localhost:5432/rag
# Elevated bootstrap connection, used only by Alembic (DDL/GRANTs). Never used by
# the running API/worker.
MIGRATOR_DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# --- Redis (arq job queue + rate limiting) ---
REDIS_URL=redis://localhost:6379/0

# --- Providers ---
LLM_PROVIDER=anthropic
EMBEDDING_PROVIDER=voyage

ANTHROPIC_API_KEY=sk-ant-changeme
LLM_MODEL=claude-opus-4-8

VOYAGE_API_KEY=pa-changeme
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_EMBEDDING_DIMENSIONS=1024

# Only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-changeme
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1024

# --- Auth ---
# Root/bootstrap key used only for POST /v1/admin/* (tenant + api-key provisioning)
ADMIN_BOOTSTRAP_KEY=changeme-root-key

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=enterprise-rag-api
